type GraphNode {
    id: ID!
    label: String
    type: String
}

type GraphEdge {
    from: ID!
    to: ID!
    type: String!
}

type GraphResponse {
    nodes: [GraphNode!]!
    edges: [GraphEdge!]!
}

type Query {
    userStoryGraph(storyId: ID!): GraphResponse
    sprintGraph(sprintId: ID!): GraphResponse
}
